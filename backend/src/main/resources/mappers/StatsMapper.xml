<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ssafy.stats.repository.StatsRepository">

    <delete id="deleteAll">
        DELETE FROM stats
    </delete>

    <insert id="insert" parameterType="com.ssafy.stats.entity.Stats">
        INSERT INTO stats (menu, price, category)
        VALUES (#{menu}, #{price}, #{category})
    </insert>

    <select id="findByMenuContaining" resultType="com.ssafy.stats.entity.Stats">
        SELECT *
        FROM stats
        WHERE menu LIKE CONCAT('%', #{keyword}, '%')
    </select>

    <!-- 🔥 평균 가격 조회 -->
    <select id="findAveragePriceByMenu" resultType="int">
        SELECT ROUND(AVG(price))
        FROM stats
        WHERE menu LIKE CONCAT('%', #{menu}, '%')
    </select>

</mapper>
